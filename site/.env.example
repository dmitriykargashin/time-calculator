# The canonical, public URL of the site. This single value drives the canonical
# tags, sitemap.xml, robots.txt, Open Graph and JSON-LD URLs — it is never
# hardcoded in the source. Set it in Vercel (Production, and Preview if you want
# previews canonicalised to prod). Copy this file to `.env` for local builds.
NUXT_SITE_URL=https://www.timecalculator.app

# Google Analytics 4 Measurement ID for the web stream (looks like G-XXXXXXXXXX).
# Leave unset locally so dev/preview send no analytics. Set it in Vercel
# (Production only) to turn GA on for the live site. Not hardcoded in source.
# NUXT_PUBLIC_GTAG_ID=G-XXXXXXXXXX
